# Server
PORT=7999
NODE_ENV=production

# MariaDB — fill in your cPanel DB credentials
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_cpanel_db_name
DB_USER=your_cpanel_db_user
DB_PASSWORD=your_cpanel_db_password

# CORS — same-origin serving, no cross-origin needed
CORS_ORIGINS=https://zuno.site,https://www.zuno.site

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STATIC_QR_ID=
RAZORPAY_CURRENCY=INR
CLIENT_URL=https://zuno.site
