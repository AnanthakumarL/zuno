# ─── Server ──────────────────────────────────────────────────────────────────
PORT=7999
NODE_ENV=production

# ─── MariaDB / MySQL ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amudhu
DB_USER=root
DB_PASSWORD=your_db_password

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Add your domain(s). When serving from the same origin this can stay empty.
CORS_ORIGINS=https://yourdomain.com

# ─── Razorpay (optional — leave blank to use mock payment only) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STATIC_QR_ID=
RAZORPAY_CURRENCY=INR
