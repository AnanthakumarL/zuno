# Server
PORT=7999
NODE_ENV=development

# MariaDB (single database for everything)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=amudhu
DB_USER=root
DB_PASSWORD=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://amudhu.click,https://www.amudhu.click,https://server.amudhu.click

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STATIC_QR_ID=
RAZORPAY_CURRENCY=INR
CLIENT_URL=http://localhost:5173

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
